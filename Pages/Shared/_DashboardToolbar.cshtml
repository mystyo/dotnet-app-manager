@model IndexModel
@{
    var runningCount = Model.ActiveProcesses.Values.Count(p => p != null);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">Dashboard</h4>
        <small class="text-muted">Scanning: @string.Join(", ", Model.CurrentPaths)</small>
    </div>
    <div class="d-flex flex-column align-items-end gap-1">
        <div class="btn-group btn-group-sm">
            <button type="button" class="btn btn-sm btn-outline-primary" id="build-all-btn">Build All</button>
            <button type="button" class="btn btn-sm btn-outline-success" id="run-all-btn">Run All</button>
            <button type="button" class="btn btn-sm btn-outline-success" id="run-selected-btn">Run Selected</button>
            <form method="post" action="/api/process/stop-all" style="display:inline">
                <button type="submit" class="btn btn-sm btn-outline-danger" id="stop-all-btn"
                        @(runningCount == 0 ? "disabled" : "")>
                    Stop All
                </button>
            </form>
            <a href="/" class="btn btn-sm btn-outline-secondary">Refresh</a>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-info" id="running-count"
                  hx-get="/api/process/running-count"
                  hx-trigger="every 3s"
                  hx-swap="innerHTML">@runningCount</span>
            <span class="text-muted small">running</span>
            <select id="build-configuration" class="form-select form-select-sm" style="width:auto">
                @foreach (var cfg in Model.BuildConfigurations)
                {
                    var isDefault = string.Equals(cfg, Model.DefaultBuildConfiguration, StringComparison.OrdinalIgnoreCase);
                    <option value="@cfg" selected="@isDefault">@cfg</option>
                }
            </select>
            <div class="form-check form-check-inline mb-0">
                <input class="form-check-input" type="checkbox" id="build-deps-checkbox" checked>
                <label class="form-check-label small" for="build-deps-checkbox">Build Dependencies</label>
            </div>
            <div class="form-check form-check-inline mb-0">
                <input class="form-check-input" type="checkbox" id="changes-only-checkbox">
                <label class="form-check-label small" for="changes-only-checkbox">Changes Only</label>
            </div>
        </div>
    </div>
</div>
