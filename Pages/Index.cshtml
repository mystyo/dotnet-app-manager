@page
@model IndexModel
@using DotnetAppManager.Models
@{
    ViewData["Title"] = "Dashboard";
}

@functions {
    void RenderDependencyTree(List<DependencyNode> nodes, int depth, HashSet<string> rendered, string ownerProjectId)
    {
        foreach (var node in nodes)
        {
            if (!rendered.Add(node.Name))
                continue;

            // Render children first (nested deps before their parent)
            if (node.Children.Count > 0)
            {
                RenderDependencyTree(node.Children, depth + 1, rendered, ownerProjectId);
            }

            var missing = node.ProjectPath == null;
            var prefix = depth > 0 ? "└ " : "";
            <li style="padding-left: @(depth * 1.2)rem;" class="d-flex align-items-center gap-2 @(missing ? "text-danger" : "")">
                <span>@prefix@node.Name</span>
                @if (missing)
                {
                    <small>(not found)</small>
                }
                else
                {
                    <button class="btn btn-outline-primary dep-build-btn" style="padding:0 .35rem; font-size:0.75em; line-height:1.4;"
                            data-dep-path="@node.ProjectPath"
                            data-dep-name="@node.Name"
                            data-owner-project-id="@ownerProjectId">
                        Build
                    </button>
                }
            </li>
        }
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">Dashboard</h4>
        <small class="text-muted">Scanning: @string.Join(", ", Model.CurrentPaths)</small>
    </div>
    @{
        var runningCount = Model.ActiveProcesses.Values.Count(p => p != null);
    }
    <div class="d-flex flex-column align-items-end gap-1">
        <div class="btn-group btn-group-sm">
            <button type="button" class="btn btn-sm btn-outline-success" id="run-all-btn">Run All</button>
            <button type="button" class="btn btn-sm btn-outline-success" id="run-selected-btn">Run Selected</button>
            <form method="post" action="/api/process/stop-all" style="display:inline">
                <button type="submit" class="btn btn-sm btn-outline-danger" id="stop-all-btn"
                        @(runningCount == 0 ? "disabled" : "")>
                    Stop All
                </button>
            </form>
            <a href="/" class="btn btn-sm btn-outline-secondary">Refresh</a>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-info" id="running-count"
                  hx-get="/api/process/running-count"
                  hx-trigger="every 3s"
                  hx-swap="innerHTML">@runningCount</span>
            <span class="text-muted small">running</span>
            <select id="build-configuration" class="form-select form-select-sm" style="width:auto">
                @foreach (var cfg in Model.BuildConfigurations)
                {
                    var isDefault = string.Equals(cfg, Model.DefaultBuildConfiguration, StringComparison.OrdinalIgnoreCase);
                    <option value="@cfg" selected="@isDefault">@cfg</option>
                }
            </select>
            <div class="form-check form-check-inline mb-0">
                <input class="form-check-input" type="checkbox" id="build-deps-checkbox" checked>
                <label class="form-check-label small" for="build-deps-checkbox">Build Dependencies</label>
            </div>
        </div>
    </div>
</div>

@if (Model.Projects.Count == 0)
{
    <div class="alert alert-info">
        No .NET projects found in the configured folders.
        <a asp-page="/Configuration">Configure target folder</a>.
    </div>
}
else
{
    <div class="d-flex gap-2 mb-3">
        <input type="text" id="project-search" class="form-control" placeholder="Filter projects by name..." autofocus />
        <select id="profile-select" class="form-select" style="width:auto; min-width:180px"
                onchange="window.location.href = this.value ? '/?profile=' + encodeURIComponent(this.value) : '/'">
            <option value="">All Projects</option>
            @foreach (var profile in Model.Profiles)
            {
                <option value="@profile.Name" selected="@(Model.SelectedProfile == profile.Name)">@profile.Name (@profile.ProjectPaths.Count)</option>
            }
        </select>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width:1rem"><input type="checkbox" id="select-all-checkbox" checked></th>
                    <th>Project</th>
                    <th>Framework</th>
                    <th>Path</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model.Projects)
                {
                    var activeProcess = Model.ActiveProcesses.GetValueOrDefault(project.Id);
                    var isRunning = activeProcess != null;
                    <tr class="project-row" data-project-name="@project.Name.ToLowerInvariant()">
                        <td><input type="checkbox" class="project-select-checkbox" data-project-id="@project.Id" data-project-path="@Uri.EscapeDataString(project.FullPath)" checked></td>
                        <td>
                            <strong>@project.Name</strong>
                            <br /><small class="text-muted">.@project.ProjectFileType</small>
                        </td>
                        <td><code>@(project.TargetFramework ?? "N/A")</code></td>
                        <td><small class="text-muted" title="@project.FullPath">@project.Directory</small></td>
                        <td id="status-@project.Id"
                            hx-get="/api/process/status/@project.Id"
                            hx-trigger="every 3s"
                            hx-swap="innerHTML">
                            @if (isRunning)
                            {
                                <span class="badge bg-info">running</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">idle</span>
                            }
                        </td>
                        @{
                            var depPaths = System.Text.Json.JsonSerializer.Serialize(
                                project.DependencyBuildOrder
                                    .Select(d => d.ProjectPath!)
                                    .ToList());
                        }
                        <td>
                            <div class="btn-group btn-group-sm" id="actions-@project.Id">
                                <button class="btn btn-outline-primary action-btn"
                                        data-action="build"
                                        data-project-id="@project.Id"
                                        data-project-path="@Uri.EscapeDataString(project.FullPath)"
                                        data-target="#console-@project.Id"
                                        data-dependencies="@depPaths">
                                    Build
                                </button>
                                <button class="btn btn-outline-success action-btn"
                                        data-action="run"
                                        data-project-id="@project.Id"
                                        data-project-path="@Uri.EscapeDataString(project.FullPath)"
                                        data-target="#console-@project.Id"
                                        data-dependencies="@depPaths">
                                    Run
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr class="project-row" data-project-name="@project.Name.ToLowerInvariant()">
                        <td colspan="6" class="p-0 border-0">
                            <div id="console-@project.Id">
                                @if (isRunning)
                                {
                                    <div class="console-wrapper mt-2" hx-ext="sse" sse-connect="/api/process/stream/@activeProcess!.Id" sse-close="close">
                                        <details open>
                                            <summary class="d-flex justify-content-between align-items-center mb-1" style="cursor:pointer;">
                                                <small class="text-muted">Running...</small>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        hx-post="/api/process/stop/@activeProcess!.Id"
                                                        hx-target="closest .console-wrapper"
                                                        hx-swap="afterbegin"
                                                        onclick="event.stopPropagation();">
                                                    Stop
                                                </button>
                                            </summary>
                                            <pre class="console-output" sse-swap="message" hx-swap="beforeend"></pre>
                                        </details>
                                    </div>
                                }
                            </div>
                        </td>
                    </tr>
                    @if (project.ProjectReferences.Count > 0)
                    {
                        <tr class="project-row" data-project-name="@project.Name.ToLowerInvariant()">
                            <td colspan="6" class="p-0 border-0">
                                <details class="mx-3 mb-2">
                                    <summary class="text-muted" style="cursor:pointer; font-size:0.85em;">
                                        Project References (@project.ProjectReferences.Count)
                                    </summary>
                                    <ul class="ms-3 mt-1 mb-2" style="font-size:0.85em;">
                                        @foreach (var reference in project.ProjectReferences)
                                        {
                                            var refMissing = !Model.KnownProjectPaths.ContainsKey(reference);
                                            <li class="@(refMissing ? "text-danger" : "")">
                                                @reference
                                                @if (refMissing)
                                                {
                                                    <small>(not found)</small>
                                                }
                                            </li>
                                        }
                                    </ul>
                                </details>
                            </td>
                        </tr>
                    }
                    @if (project.DependencyTree.Count > 0)
                    {
                        var directCount = project.DependencyNames.Count;
                        var totalCount = project.DependencyBuildOrder.Count;
                        var nestedCount = totalCount - directCount;
                        <tr class="project-row" data-project-name="@project.Name.ToLowerInvariant()">
                            <td colspan="6" class="p-0 border-0">
                                <details class="mx-3 mb-2">
                                    <summary class="text-muted" style="cursor:pointer; font-size:0.85em;">
                                        Dependencies (@directCount direct@(nestedCount > 0 ? $", {nestedCount} nested" : ""))
                                    </summary>
                                    <ul class="ms-3 mt-1 mb-2" style="font-size:0.85em; list-style: none; padding-left: 0;">
                                        @{ RenderDependencyTree(project.DependencyTree, 0, new HashSet<string>(StringComparer.OrdinalIgnoreCase), project.Id); }
                                    </ul>
                                </details>
                            </td>
                        </tr>
                    }
                    @if (project.AppSettings.Count > 0)
                    {
                        <tr class="project-row" data-project-name="@project.Name.ToLowerInvariant()">
                            <td colspan="6" class="p-0 border-0">
                                <details class="mx-3 mb-2">
                                    <summary class="text-muted" style="cursor:pointer; font-size:0.85em;">
                                        App Settings (@project.AppSettings.Count file(s))
                                    </summary>
                                    @foreach (var (fileName, settings) in project.AppSettings)
                                    {
                                        <div class="ms-3 mt-1">
                                            <strong class="small">@fileName</strong>
                                            <table class="table table-sm table-bordered mt-1 mb-2" style="font-size:0.8em;">
                                                <thead class="table-dark">
                                                    <tr><th>Key</th><th>Value</th></tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var (key, value) in settings)
                                                    {
                                                        <tr>
                                                            <td><code>@key</code></td>
                                                            <td>@value</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </details>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <script>
        function getSelectedConfiguration() {
            return document.getElementById('build-configuration').value;
        }

        document.getElementById('project-search').addEventListener('input', function () {
            var filter = this.value.toLowerCase();
            document.querySelectorAll('.project-row').forEach(function (row) {
                var name = row.getAttribute('data-project-name');
                row.style.display = name.includes(filter) ? '' : 'none';
            });
        });

        document.querySelectorAll('.action-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var action = this.getAttribute('data-action');
                var projectId = this.getAttribute('data-project-id');
                var projectPath = this.getAttribute('data-project-path');
                var target = this.getAttribute('data-target');
                var config = getSelectedConfiguration();
                var buildDeps = document.getElementById('build-deps-checkbox').checked;
                var deps = JSON.parse(this.getAttribute('data-dependencies') || '[]');

                if (buildDeps && deps.length > 0) {
                    var url = '/api/process/build-chain';
                    var body = JSON.stringify({
                        projectId: projectId,
                        projectPath: decodeURIComponent(projectPath),
                        action: action,
                        configuration: config,
                        dependencyPaths: deps
                    });
                    fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: body
                    }).then(function (r) { return r.text(); })
                      .then(function (html) {
                          document.querySelector(target).innerHTML = html;
                          htmx.process(document.querySelector(target));
                      });
                } else {
                    var url = '/api/process/' + action + '?projectId=' + projectId + '&projectPath=' + projectPath + '&configuration=' + encodeURIComponent(config);
                    htmx.ajax('POST', url, { target: target, swap: 'innerHTML' });
                }
            });
        });

        document.getElementById('select-all-checkbox').addEventListener('change', function () {
            var checked = this.checked;
            document.querySelectorAll('.project-select-checkbox').forEach(function (cb) {
                cb.checked = checked;
            });
        });

        document.getElementById('run-all-btn').addEventListener('click', function () {
            var config = getSelectedConfiguration();
            var profile = document.getElementById('profile-select').value;
            var url = '/api/process/run-all?configuration=' + encodeURIComponent(config);
            if (profile) url += '&profile=' + encodeURIComponent(profile);
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = url;
            document.body.appendChild(form);
            form.submit();
        });

        document.getElementById('run-selected-btn').addEventListener('click', function () {
            var config = getSelectedConfiguration();
            var selected = document.querySelectorAll('.project-select-checkbox:checked');
            if (selected.length === 0) return;
            selected.forEach(function (cb) {
                var projectId = cb.getAttribute('data-project-id');
                var projectPath = cb.getAttribute('data-project-path');
                var target = '#console-' + projectId;
                var url = '/api/process/run?projectId=' + projectId + '&projectPath=' + projectPath + '&configuration=' + encodeURIComponent(config);
                htmx.ajax('POST', url, { target: target, swap: 'innerHTML' });
            });
        });

        function setProjectActionsDisabled(projectId, disabled) {
            var group = document.getElementById('actions-' + projectId);
            if (!group) return;
            group.querySelectorAll('button').forEach(function (btn) {
                btn.disabled = disabled;
            });
        }

        document.body.addEventListener('click', function (e) {
            var btn = e.target.closest('.dep-build-btn');
            if (!btn) return;

            var depPath = btn.getAttribute('data-dep-path');
            var depName = btn.getAttribute('data-dep-name');
            var ownerProjectId = btn.getAttribute('data-owner-project-id');
            var config = getSelectedConfiguration();
            var target = '#console-' + ownerProjectId;

            // Disable the project's Build/Run buttons
            setProjectActionsDisabled(ownerProjectId, true);
            btn.disabled = true;

            var url = '/api/process/build?projectId=' + ownerProjectId + '&projectPath=' + encodeURIComponent(depPath) + '&configuration=' + encodeURIComponent(config);
            fetch(url, { method: 'POST' })
                .then(function (r) { return r.text(); })
                .then(function (html) {
                    document.querySelector(target).innerHTML = html;
                    htmx.process(document.querySelector(target));

                    // Poll for completion to re-enable buttons
                    var pollInterval = setInterval(function () {
                        var consoleEl = document.querySelector(target);
                        // SSE connection closed means build finished (sse-connect attribute removed or details no longer has open stream)
                        var sseEl = consoleEl && consoleEl.querySelector('[sse-connect]');
                        if (!sseEl || !sseEl.querySelector('.console-output')) {
                            clearInterval(pollInterval);
                            setProjectActionsDisabled(ownerProjectId, false);
                            btn.disabled = false;
                            return;
                        }
                        // Check if the stream has ended by looking for a status badge
                        var statusBadge = sseEl.querySelector('.badge');
                        if (statusBadge) {
                            clearInterval(pollInterval);
                            setProjectActionsDisabled(ownerProjectId, false);
                            btn.disabled = false;
                        }
                    }, 1000);
                });
        });

        document.body.addEventListener('htmx:afterSwap', function (evt) {
            if (evt.detail.target.id === 'running-count') {
                var count = parseInt(evt.detail.target.innerText) || 0;
                document.getElementById('stop-all-btn').disabled = count === 0;
            }
        });

        // Re-enable action buttons when SSE close event fires (build/run finished)
        document.body.addEventListener('htmx:sseClose', function (evt) {
            var wrapper = evt.target.closest('.console-wrapper');
            if (!wrapper) return;
            var consoleDiv = wrapper.closest('[id^="console-"]');
            if (!consoleDiv) return;
            var projectId = consoleDiv.id.replace('console-', '');
            setProjectActionsDisabled(projectId, false);
        });
    </script>
}
